<script>
  // 48-hour countdown timer
  let countdownDuration = 48 * 60 * 60; // 48 hours in seconds
  const timerEl = document.getElementById("timer");

  function updateTimer() {
    const hours = Math.floor(countdownDuration / 3600);
    const minutes = Math.floor((countdownDuration % 3600) / 60);
    const seconds = countdownDuration % 60;

    timerEl.textContent = 
      String(hours).padStart(2,'0') + ":" +
      String(minutes).padStart(2,'0') + ":" +
      String(seconds).padStart(2,'0');

    if (countdownDuration > 0) {
      countdownDuration--;
    } else {
      clearInterval(interval);
      timerEl.textContent = "Registration Closed";
    }
  }

  const interval = setInterval(updateTimer, 1000);
  updateTimer();
</script>

